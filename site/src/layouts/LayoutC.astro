---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Pear Tree Community School — Social justice Montessori education in Oakland, CA.' } = Astro.props;
const pageTitle = title === 'Home' ? 'Pear Tree Community School' : `${title} | Pear Tree CS`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    @tailwind base;
    @tailwind components;
    @tailwind utilities;
  </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased" style="font-family: 'Inter', -apple-system, sans-serif;">
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href={`${import.meta.env.BASE_URL}/v3`} class="flex items-center gap-3">
        <img src={`${import.meta.env.BASE_URL}/images/logo.jpg`} alt="Pear Tree" class="h-8 w-auto" />
        <div>
          <span class="text-sm font-semibold text-slate-900">Pear Tree Community School</span>
        </div>
      </a>
      <div class="hidden md:flex items-center gap-6 text-[13px] font-medium text-slate-500">
        <a href={`${import.meta.env.BASE_URL}/v3/about`} class="hover:text-slate-900 transition-colors">About</a>
        <a href={`${import.meta.env.BASE_URL}/v3/programs`} class="hover:text-slate-900 transition-colors">Programs</a>
        <a href={`${import.meta.env.BASE_URL}/v3/admissions`} class="hover:text-slate-900 transition-colors">Admissions</a>
        <a href={`${import.meta.env.BASE_URL}/v3/contact`} class="hover:text-slate-900 transition-colors">Contact</a>
        <a href={`${import.meta.env.BASE_URL}/v3/support#give`} class="px-4 py-1.5 bg-emerald-600 text-white rounded-md text-[13px] font-medium hover:bg-emerald-700 transition-colors">Donate</a>
      </div>
    </div>
  </nav>

  <main class="pt-14">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-white border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-12 grid md:grid-cols-4 gap-8 text-sm">
      <div>
        <h4 class="font-semibold text-slate-900 mb-3">Pear Tree CS</h4>
        <p class="text-slate-500 leading-relaxed">Social justice Montessori education serving preschool through 5th grade in Oakland, CA.</p>
      </div>
      <div>
        <h4 class="font-semibold text-slate-900 mb-3">Quick Links</h4>
        <div class="space-y-2 text-slate-500">
          <a href={`${import.meta.env.BASE_URL}/v3/programs`} class="block hover:text-slate-900">Programs</a>
          <a href={`${import.meta.env.BASE_URL}/v3/admissions`} class="block hover:text-slate-900">Admissions</a>
          <a href={`${import.meta.env.BASE_URL}/v3/support`} class="block hover:text-slate-900">Give</a>
        </div>
      </div>
      <div>
        <h4 class="font-semibold text-slate-900 mb-3">Preschool Campus</h4>
        <p class="text-slate-500">8100 Winthrope Street<br />Oakland, CA</p>
      </div>
      <div>
        <h4 class="font-semibold text-slate-900 mb-3">Elementary Campus</h4>
        <p class="text-slate-500">6925 Chabot Road<br />Oakland, CA 94618</p>
      </div>
    </div>
    <div class="border-t border-slate-100 max-w-7xl mx-auto px-6 py-4">
      <p class="text-xs text-slate-400">&copy; {new Date().getFullYear()} Pear Tree Community School, LLC</p>
    </div>
  </footer>
</body>
</html>
