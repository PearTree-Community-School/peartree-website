---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admissions" description="Apply to Pear Tree Community School. 80% of families receive financial aid. No family is turned away due to inability to pay.">

  <!-- Page Header -->
  <section class="bg-forest-900 text-white">
    <div class="section-padding py-16 md:py-24">
      <p class="text-pear-400 font-semibold text-sm uppercase tracking-widest mb-4">Admissions</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold leading-tight max-w-3xl">
        Every child belongs here.
      </h1>
      <p class="text-forest-200 text-lg mt-4 max-w-2xl">
        We believe that a liberatory education should be available to every family, not just those who can afford it.
      </p>
    </div>
  </section>

  <!-- Financial Aid -->
  <section class="bg-pear-50 border-b border-pear-100">
    <div class="section-padding">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="section-heading">No family will be turned away.</h2>
        <p class="text-earth-700 leading-relaxed mb-6">
          80% of Pear Tree families receive financial aid. We offer a sliding scale based on each family's financial situation because we believe access to excellent education is a right, not a privilege.
        </p>
        <div class="bg-white rounded-xl p-8 border border-pear-200 text-left">
          <h3 class="font-serif font-bold text-lg mb-4">Financial Aid at a Glance</h3>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-forest-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
              <span class="text-earth-700 text-sm">80% of families receive need-based financial aid</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-forest-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
              <span class="text-earth-700 text-sm">Sliding scale tuition based on ability to pay</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-forest-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
              <span class="text-earth-700 text-sm">No family has ever been turned away due to inability to pay</span>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-forest-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
              <span class="text-earth-700 text-sm">BASIC Fund scholarships available (up to $2,750/year per child)</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Programs Available -->
  <section class="section-padding">
    <h2 class="section-heading text-center mb-12">Programs &amp; Schedules</h2>

    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <div class="bg-white rounded-xl p-8 border border-earth-100">
        <h3 class="font-serif text-xl font-bold mb-4">Preschool</h3>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between border-b border-earth-50 pb-2">
            <span class="text-earth-600">Ages</span>
            <span class="font-medium">2+</span>
          </div>
          <div class="flex justify-between border-b border-earth-50 pb-2">
            <span class="text-earth-600">Hours</span>
            <span class="font-medium">8:00 AM &ndash; 5:00 PM</span>
          </div>
          <div class="flex justify-between border-b border-earth-50 pb-2">
            <span class="text-earth-600">Days</span>
            <span class="font-medium">Monday &ndash; Friday</span>
          </div>
          <div class="flex justify-between">
            <span class="text-earth-600">Campus</span>
            <span class="font-medium">8100 Winthrope St</span>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl p-8 border border-earth-100">
        <h3 class="font-serif text-xl font-bold mb-4">Elementary (TK&ndash;5)</h3>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between border-b border-earth-50 pb-2">
            <span class="text-earth-600">Grades</span>
            <span class="font-medium">TK through 5th</span>
          </div>
          <div class="flex justify-between border-b border-earth-50 pb-2">
            <span class="text-earth-600">Hours</span>
            <span class="font-medium">8:30 AM &ndash; 3:30 PM</span>
          </div>
          <div class="flex justify-between border-b border-earth-50 pb-2">
            <span class="text-earth-600">Days</span>
            <span class="font-medium">Monday &ndash; Friday</span>
          </div>
          <div class="flex justify-between">
            <span class="text-earth-600">Campus</span>
            <span class="font-medium">6925 Chabot Rd</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Apply -->
  <section class="bg-white">
    <div class="section-padding">
      <h2 class="section-heading text-center mb-12">How to Join Our Community</h2>

      <div class="max-w-3xl mx-auto">
        <div class="space-y-8">
          {[
            { step: '1', title: 'Schedule a Tour', desc: 'Visit our campus, meet our teachers, and see Montessori in action. Tours are the best way to experience what makes Pear Tree different.' },
            { step: '2', title: 'Submit an Application', desc: 'Complete the application form and share your family\'s story with us. We review each application holistically — there are no test scores or academic prerequisites.' },
            { step: '3', title: 'Financial Aid Conversation', desc: 'We\'ll work with every family to find a tuition level that works. Our commitment to access means we will find a way.' },
            { step: '4', title: 'Welcome to Pear Tree', desc: 'Once accepted, you\'ll join a community of families who are invested in building something different together.' },
          ].map(item => (
            <div class="flex gap-6">
              <div class="w-12 h-12 bg-forest-600 text-white font-serif font-bold rounded-full flex items-center justify-center flex-shrink-0 text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="font-serif text-xl font-bold mb-1">{item.title}</h3>
                <p class="text-earth-600 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-forest-50">
    <div class="section-padding">
      <h2 class="section-heading text-center mb-12">What families say</h2>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {[
          { quote: 'The thoughtfulness, creativity and love of the teachers — staff really "see" each child and support healthy peer relationships.', source: 'Current Parent' },
          { quote: 'Students develop deep understanding of the foundational principles from the Montessori materials and excel at applying learning to real-world contexts.', source: 'Current Parent' },
          { quote: 'The school creates an inclusive and caring learning environment where children develop confidence and emotional expression.', source: 'Current Parent' },
          { quote: 'The community has unprecedented love and support among families and staff.', source: 'Current Parent' },
        ].map(item => (
          <blockquote class="bg-white rounded-xl p-6 border border-forest-100">
            <p class="text-earth-700 italic leading-relaxed text-sm">"{item.quote}"</p>
            <footer class="mt-3 text-xs text-earth-500">&mdash; {item.source}, via Berkeley Parents Network</footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-forest-700 text-white">
    <div class="section-padding text-center">
      <h2 class="font-serif text-3xl font-bold mb-4">Ready to learn more?</h2>
      <p class="text-forest-200 max-w-xl mx-auto mb-8">
        Schedule a campus tour to see our classrooms, meet our teachers, and learn how Pear Tree can be the right fit for your family.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${import.meta.env.BASE_URL}/contact`} class="btn-primary bg-pear-500 hover:bg-pear-600 text-charcoal font-bold">Schedule a Tour</a>
        <a href="tel:+15108174690" class="btn-secondary border-white/30 text-white hover:bg-white/10">Call (510) 817-4690</a>
      </div>
    </div>
  </section>

</Layout>
