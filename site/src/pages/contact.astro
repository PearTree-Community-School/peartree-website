---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact Pear Tree Community School in Oakland, CA. Schedule a tour, ask about admissions, or connect with our community.">

  <!-- Page Header -->
  <section class="bg-forest-900 text-white">
    <div class="section-padding py-16 md:py-24">
      <p class="text-pear-400 font-semibold text-sm uppercase tracking-widest mb-4">Contact Us</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold leading-tight max-w-3xl">
        We'd love to hear from you.
      </h1>
    </div>
  </section>

  <section class="section-padding">
    <div class="grid md:grid-cols-2 gap-12">

      <!-- Contact Info -->
      <div>
        <h2 class="section-heading mb-8">Get in Touch</h2>

        <div class="space-y-6">
          <div>
            <h3 class="font-serif font-bold text-lg mb-1">Phone</h3>
            <a href="tel:+15108174690" class="text-forest-600 hover:text-forest-800 transition-colors">(510) 817-4690</a>
          </div>

          <div>
            <h3 class="font-serif font-bold text-lg mb-1">Email</h3>
            <a href="mailto:admin@peartreecs.com" class="text-forest-600 hover:text-forest-800 transition-colors">admin@peartreecs.com</a>
          </div>

          <div>
            <h3 class="font-serif font-bold text-lg mb-1">Facebook</h3>
            <a href="https://www.facebook.com/peartreecs/" target="_blank" rel="noopener" class="text-forest-600 hover:text-forest-800 transition-colors">facebook.com/peartreecs</a>
          </div>
        </div>

        <hr class="my-8 border-earth-200" />

        <!-- Campuses -->
        <div class="space-y-6">
          <div>
            <h3 class="font-serif font-bold text-lg mb-2">Preschool Campus</h3>
            <address class="not-italic text-earth-600 leading-relaxed">
              8100 Winthrope Street<br />
              Oakland, CA
            </address>
            <p class="text-sm text-earth-500 mt-1">Mon&ndash;Fri, 8:00 AM &ndash; 5:00 PM</p>
            <a
              href="https://maps.google.com/?q=8100+Winthrope+Street+Oakland+CA"
              target="_blank"
              rel="noopener"
              class="text-sm text-forest-600 hover:text-forest-800 transition-colors mt-1 inline-block"
            >
              View on Google Maps &rarr;
            </a>
          </div>

          <div>
            <h3 class="font-serif font-bold text-lg mb-2">Elementary Campus</h3>
            <address class="not-italic text-earth-600 leading-relaxed">
              6925 Chabot Road<br />
              Oakland, CA 94618
            </address>
            <p class="text-sm text-earth-500 mt-1">Mon&ndash;Fri, 8:30 AM &ndash; 3:30 PM</p>
            <a
              href="https://maps.google.com/?q=6925+Chabot+Road+Oakland+CA+94618"
              target="_blank"
              rel="noopener"
              class="text-sm text-forest-600 hover:text-forest-800 transition-colors mt-1 inline-block"
            >
              View on Google Maps &rarr;
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <div class="bg-white rounded-2xl p-8 border border-earth-100">
          <h2 class="font-serif text-2xl font-bold mb-2">Send Us a Message</h2>
          <p class="text-earth-500 text-sm mb-6">Interested in a tour, enrollment, or volunteering? Let us know.</p>

          <form name="contact" method="POST" data-netlify="true" class="space-y-5">
            <input type="hidden" name="form-name" value="contact" />

            <div>
              <label for="name" class="block text-sm font-medium text-charcoal mb-1">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-earth-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent bg-cream"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-charcoal mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-earth-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent bg-cream"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-charcoal mb-1">Phone <span class="text-earth-400">(optional)</span></label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-4 py-3 border border-earth-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent bg-cream"
              />
            </div>

            <div>
              <label for="interest" class="block text-sm font-medium text-charcoal mb-1">I'm interested in</label>
              <select
                id="interest"
                name="interest"
                class="w-full px-4 py-3 border border-earth-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent bg-cream"
              >
                <option value="">Select one...</option>
                <option value="tour">Scheduling a tour</option>
                <option value="preschool">Preschool enrollment</option>
                <option value="elementary">Elementary enrollment</option>
                <option value="summer-camp">Summer camp</option>
                <option value="volunteer">Volunteering</option>
                <option value="donate">Making a donation</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-charcoal mb-1">Message</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full px-4 py-3 border border-earth-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent bg-cream resize-y"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full text-center">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>
