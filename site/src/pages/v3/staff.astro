---
import LayoutC from '../../layouts/LayoutC.astro';
import StaffRequestForm from '../../components/StaffRequestForm.astro';
import { requestCategories } from '../../data/staffRequestCategories';
import { phone, phoneTel, email } from '../../data/campusInfo';
---

<LayoutC title="Staff Portal" description="Pear Tree staff portal — submit work requests.">

  <!-- Hero -->
  <section class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <span class="inline-block bg-emerald-50 text-emerald-700 text-xs font-medium px-3 py-1 rounded-full uppercase tracking-wide mb-4">Staff Portal</span>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight">Submit a work request.</h1>
      <p class="text-lg text-slate-600 mt-6 max-w-2xl">Facilities, supplies, tech, Montessori materials, or anything else you need.</p>
    </div>
  </section>

  <!-- Auth banner -->
  <section class="bg-amber-50 border-b border-amber-200">
    <div class="max-w-7xl mx-auto px-6 py-3">
      <p class="text-sm text-amber-900">
        <strong>Open submissions for now.</strong> Email-invite login coming soon. Requests email <a href={`mailto:${email}`} class="underline">{email}</a>.
      </p>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 py-16 grid md:grid-cols-12 gap-8">

      <div class="md:col-span-4 space-y-6">
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <h3 class="font-semibold text-slate-900 mb-4">What can I request?</h3>
          <ul class="space-y-3">
            {requestCategories.map(c => (
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-emerald-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                <div>
                  <p class="font-medium text-slate-900 text-sm">{c.label}</p>
                  <p class="text-xs text-slate-500">{c.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <h3 class="font-semibold text-slate-900 mb-2">Urgent?</h3>
          <p class="text-sm text-slate-600 mb-3">If something is dangerous or blocking your class right now, please call directly.</p>
          <a href={phoneTel} class="text-emerald-700 font-semibold hover:text-emerald-800">{phone}</a>
        </div>
      </div>

      <div class="md:col-span-8">
        <div class="bg-white rounded-xl p-8 border border-slate-200">
          <h2 class="text-2xl font-bold text-slate-900 mb-2">New request</h2>
          <p class="text-sm text-slate-500 mb-6">Required fields marked with *. Photos help.</p>
          <StaffRequestForm variant="v3" />
        </div>
      </div>
    </div>
  </section>

</LayoutC>
