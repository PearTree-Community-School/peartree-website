---
import LayoutC from '../../layouts/LayoutC.astro';
import { tagline, fullMission, missionContext, baldwinQuote } from '../../data/missionStatement';
import { statsList } from '../../data/schoolStats';
import { mirrorPillars, mirrorIntro } from '../../data/mirrorFramework';
import { philosophyPillars } from '../../data/educationalPhilosophy';
import { recognitions } from '../../data/recognition';
import { articles, MICHELE_MEDIUM_PROFILE } from '../../data/medium-articles';

const BASE = import.meta.env.BASE_URL;
---

<LayoutC title="About" description="About Pear Tree Community School — founder, mission, MIRROR Framework.">

  <!-- Hero -->
  <section class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24 grid md:grid-cols-12 gap-12 items-end">
      <div class="md:col-span-8">
        <span class="inline-block bg-emerald-50 text-emerald-700 text-xs font-medium px-3 py-1 rounded-full uppercase tracking-wide mb-4">About</span>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight">{tagline}</h1>
        <p class="text-lg text-slate-600 mt-6 max-w-2xl">A social justice Montessori school in Oakland serving preschool through 5th grade.</p>
      </div>
      <div class="md:col-span-4">
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
          <p class="text-xs uppercase tracking-wider text-slate-500 mb-4">By the Numbers</p>
          <div class="space-y-3">
            {statsList.map(s => (
              <div class="flex justify-between items-baseline">
                <span class="text-sm text-slate-600">{s.label}</span>
                <span class="font-semibold text-slate-900">{s.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-wider text-emerald-700 font-medium mb-3">Our Mission</p>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">A liberatory education, by design.</h2>
        <p class="text-lg text-slate-700 leading-relaxed mb-4">{fullMission}</p>
        <p class="text-lg text-slate-700 leading-relaxed">{missionContext}</p>
      </div>
    </div>
  </section>

  <!-- MIRROR Framework -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <div class="max-w-3xl mb-12">
        <p class="text-xs uppercase tracking-wider text-emerald-700 font-medium mb-3">The Framework</p>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">The MIRROR Framework</h2>
        <p class="text-slate-600">{mirrorIntro}</p>
      </div>

      <div class="rounded-xl overflow-hidden border border-slate-200 mb-12 max-w-4xl mx-auto">
        <img loading="lazy" decoding="async" src={`${BASE}/images/photos/mirror-framework.png`} alt="The MIRROR Framework infographic" class="w-full h-auto" />
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {mirrorPillars.map((p, i) => (
          <div class="bg-slate-50 rounded-xl p-6 hover:shadow-lg transition-shadow">
            <div class="flex items-center gap-3 mb-3">
              <span class="w-9 h-9 bg-emerald-600 text-white font-bold rounded-full flex items-center justify-center text-sm">{i + 1}</span>
              <h3 class="font-semibold text-slate-900">{p.title}</h3>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Educational Philosophy -->
  <section class="bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-12">Educational Philosophy</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {philosophyPillars.map(p => (
          <div class="bg-white rounded-xl p-6 border border-slate-200">
            <div class="flex items-start gap-3 mb-3">
              <svg class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              <h3 class="font-semibold text-slate-900">{p.title}</h3>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed pl-8">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Founder -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24 grid md:grid-cols-5 gap-12 items-start">
      <div class="md:col-span-2">
        <div class="rounded-xl overflow-hidden aspect-square">
          <img loading="lazy" decoding="async" src={`${BASE}/images/photos/michele-hamilton.jpg`} alt="Michele Hamilton" class="w-full h-full object-cover" />
        </div>
      </div>
      <div class="md:col-span-3">
        <span class="inline-block bg-emerald-50 text-emerald-700 text-xs font-medium px-3 py-1 rounded-full uppercase tracking-wide mb-3">The Founder</span>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-2">Michele Hamilton</h2>
        <p class="text-sm text-slate-500 uppercase tracking-wide mb-6">Founder &amp; Head of School · Educational Researcher</p>
        <p class="text-slate-700 leading-relaxed mb-4">
          A trailblazing educator with 27+ years of experience in transformative educational change. Michele grew up in a low-income household in East Oakland and navigated the Oakland Unified School District despite early academic struggles — an experience that fueled her lifelong commitment to educational equity and liberation.
        </p>
        <p class="text-slate-700 leading-relaxed mb-6">
          She founded Pear Tree as both a model school and a vital training site for educational policy development. She established <a href="https://www.seedstorootsoakland.com/" target="_blank" rel="noopener" class="text-emerald-700 font-medium hover:text-emerald-800">Seeds to Roots Oakland</a> to scale the Pear Tree model nationally, and is the author of <em>Raising Black and Brown Children</em>.
        </p>
        <blockquote class="bg-slate-50 border-l-4 border-emerald-600 rounded-r-lg p-6 mb-6">
          <p class="text-slate-700 italic leading-relaxed">"{baldwinQuote.quote}"</p>
          <footer class="text-xs text-slate-500 mt-3 not-italic">— {baldwinQuote.source}</footer>
        </blockquote>
        <a href={MICHELE_MEDIUM_PROFILE} target="_blank" rel="noopener" class="inline-block px-5 py-2.5 bg-emerald-600 text-white rounded-md text-sm font-medium hover:bg-emerald-700">
          Read Michele's Essays →
        </a>
      </div>
    </div>
  </section>

  <!-- Articles -->
  <section class="bg-slate-50 border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
        <div>
          <p class="text-xs uppercase tracking-wider text-emerald-700 font-medium mb-3">Writings</p>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900">From Michele's Desk</h2>
        </div>
        <a href={MICHELE_MEDIUM_PROFILE} target="_blank" rel="noopener" class="text-sm text-emerald-700 hover:text-emerald-800 font-medium">View all on Medium →</a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.slice(0, 6).map(a => (
          <a href={a.url} target="_blank" rel="noopener" class="block bg-white rounded-xl p-6 border border-slate-200 hover:shadow-lg hover:border-emerald-200 transition-all">
            <p class="text-xs uppercase tracking-wider text-slate-500 mb-3">{new Date(a.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}{a.publication ? ` · ${a.publication}` : ''}</p>
            <h3 class="text-lg font-semibold text-slate-900 leading-snug mb-2">{a.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{a.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recognition -->
  <section class="bg-white border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <p class="text-xs uppercase tracking-wider text-slate-500 text-center mb-8">Recognition</p>
      <div class="grid md:grid-cols-3 gap-8">
        {recognitions.map(r => (
          <div class="text-center">
            <h3 class="font-semibold text-slate-900 mb-2">{r.org}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Seeds to Roots -->
  <section class="bg-emerald-600 text-white">
    <div class="max-w-5xl mx-auto px-6 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Pear Tree isn't just a school — it's a demonstration site.</h2>
      <p class="text-emerald-50 max-w-2xl mx-auto mb-10">
        Through Seeds to Roots Oakland, our sister organization, educators from across the country observe the Pear Tree Framework in action.
      </p>
      <a href="https://www.seedstorootsoakland.com/" target="_blank" rel="noopener" class="inline-block px-6 py-3 bg-white text-emerald-700 rounded-md text-sm font-medium hover:bg-emerald-50">
        Visit Seeds to Roots →
      </a>
    </div>
  </section>

</LayoutC>
