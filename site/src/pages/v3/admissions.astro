---
import LayoutC from '../../layouts/LayoutC.astro';
import { admissionProcess, aidPoints } from '../../data/admissionProcess';
import { testimonials } from '../../data/testimonials';
import { preschool, elementary, phone, phoneTel } from '../../data/campusInfo';

const BASE = import.meta.env.BASE_URL;
---

<LayoutC title="Admissions" description="Apply to Pear Tree Community School. 80% of families receive financial aid.">

  <!-- Hero -->
  <section class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <span class="inline-block bg-emerald-50 text-emerald-700 text-xs font-medium px-3 py-1 rounded-full uppercase tracking-wide mb-4">Admissions</span>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight max-w-3xl">Every child belongs here.</h1>
      <p class="text-lg text-slate-600 mt-6 max-w-2xl">A liberatory education should be available to every family — not just those who can afford it.</p>
    </div>
  </section>

  <!-- No family will be turned away -->
  <section class="bg-slate-50">
    <div class="max-w-5xl mx-auto px-6 py-20 md:py-24">
      <div class="bg-white rounded-2xl p-10 md:p-12 border border-slate-200">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">No family will be turned away.</h2>
        <p class="text-slate-700 leading-relaxed mb-8">
          80% of Pear Tree families receive financial aid. We offer a sliding scale based on each family's situation because we believe access to excellent education is a right, not a privilege.
        </p>
        <ul class="space-y-3">
          {aidPoints.map(point => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              <span class="text-slate-700">{point}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Programs Schedule -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-12">Programs &amp; Schedules</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-slate-50 rounded-xl p-8 border border-slate-200">
          <h3 class="font-semibold text-slate-900 text-lg mb-6">Preschool</h3>
          <dl class="space-y-3 text-sm">
            <div class="flex justify-between border-b border-slate-200 pb-2"><dt class="text-slate-500">Ages</dt><dd class="font-medium text-slate-900">{preschool.ages}</dd></div>
            <div class="flex justify-between border-b border-slate-200 pb-2"><dt class="text-slate-500">Hours</dt><dd class="font-medium text-slate-900">{preschool.hours}</dd></div>
            <div class="flex justify-between border-b border-slate-200 pb-2"><dt class="text-slate-500">Days</dt><dd class="font-medium text-slate-900">{preschool.days}</dd></div>
            <div class="flex justify-between"><dt class="text-slate-500">Campus</dt><dd class="font-medium text-slate-900">{preschool.address}</dd></div>
          </dl>
        </div>
        <div class="bg-slate-50 rounded-xl p-8 border border-slate-200">
          <h3 class="font-semibold text-slate-900 text-lg mb-6">Elementary (TK–5)</h3>
          <dl class="space-y-3 text-sm">
            <div class="flex justify-between border-b border-slate-200 pb-2"><dt class="text-slate-500">Grades</dt><dd class="font-medium text-slate-900">TK through 5th</dd></div>
            <div class="flex justify-between border-b border-slate-200 pb-2"><dt class="text-slate-500">Hours</dt><dd class="font-medium text-slate-900">{elementary.hours}</dd></div>
            <div class="flex justify-between border-b border-slate-200 pb-2"><dt class="text-slate-500">Days</dt><dd class="font-medium text-slate-900">{elementary.days}</dd></div>
            <div class="flex justify-between"><dt class="text-slate-500">Campus</dt><dd class="font-medium text-slate-900">{elementary.address}</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="bg-slate-50 border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-12">How to Join Our Community</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {admissionProcess.map(s => (
          <div class="bg-white rounded-xl p-6 border border-slate-200">
            <span class="w-10 h-10 bg-emerald-600 text-white font-bold rounded-full flex items-center justify-center text-sm mb-4">{s.step}</span>
            <h3 class="font-semibold text-slate-900 mb-2">{s.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-12">What families say</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {testimonials.map(t => (
          <blockquote class="bg-slate-50 rounded-xl p-6 border border-slate-200">
            <p class="text-slate-700 italic leading-relaxed">"{t.quote}"</p>
            <footer class="text-xs text-slate-500 mt-4 not-italic">— {t.source}{t.origin ? `, via ${t.origin}` : ''}</footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-emerald-600 text-white">
    <div class="max-w-4xl mx-auto px-6 py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to learn more?</h2>
      <p class="text-emerald-50 mb-10 max-w-2xl mx-auto">Schedule a campus tour to see our classrooms, meet our teachers, and learn how Pear Tree can be the right fit for your family.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${BASE}/v3/tour`} class="inline-block px-6 py-3 bg-white text-emerald-700 rounded-md text-sm font-medium hover:bg-emerald-50">Schedule a Tour</a>
        <a href={phoneTel} class="inline-block px-6 py-3 border border-white/40 rounded-md text-sm font-medium hover:bg-white/10">Call {phone}</a>
      </div>
    </div>
  </section>

</LayoutC>
