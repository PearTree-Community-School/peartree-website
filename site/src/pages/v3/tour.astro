---
import LayoutC from '../../layouts/LayoutC.astro';
import TourForm from '../../components/TourForm.astro';
import { tourCopy } from '../../data/tourInfo';
import { phone, phoneTel, email } from '../../data/campusInfo';
---

<LayoutC title="Schedule a Tour" description="Schedule a campus tour at Pear Tree Community School.">

  <!-- Hero -->
  <section class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-16 md:py-20">
      <span class="inline-block bg-emerald-50 text-emerald-700 text-xs font-medium px-3 py-1 rounded-full uppercase tracking-wide mb-4">Visit Pear Tree</span>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight max-w-3xl">Schedule a tour of our campus.</h1>
      <p class="text-lg text-slate-600 mt-6 max-w-2xl">{tourCopy.schedule}. {tourCopy.responseTime}</p>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 py-16 grid md:grid-cols-12 gap-8">

      <div class="md:col-span-4 space-y-6">
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <h3 class="font-semibold text-slate-900 mb-4">What to expect</h3>
          <ul class="space-y-3 text-sm text-slate-700">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-emerald-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span>A walkthrough of our classrooms and outdoor spaces</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-emerald-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span>Time with our founder or admissions team</span></li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-emerald-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span>An honest conversation about financial aid</span></li>
          </ul>
        </div>

        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <h3 class="font-semibold text-slate-900 mb-3">Prefer to call?</h3>
          <p class="text-sm"><a href={phoneTel} class="text-emerald-700 hover:text-emerald-800 font-medium">{phone}</a></p>
          <p class="text-sm mt-1"><a href={`mailto:${email}`} class="text-emerald-700 hover:text-emerald-800 font-medium">{email}</a></p>
        </div>
      </div>

      <div class="md:col-span-8">
        <div class="bg-white rounded-xl p-8 border border-slate-200">
          <h2 class="text-2xl font-bold text-slate-900 mb-2">Tour registration</h2>
          <p class="text-sm text-slate-500 mb-6">Required fields marked with *.</p>
          <TourForm variant="v3" />
        </div>
      </div>
    </div>
  </section>

</LayoutC>
