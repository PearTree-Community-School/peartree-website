---

<LayoutC title="Parent Portal" description="Pear Tree Community School parent portal — calendar, messages, photos, FAQ, and ParentSquare quick links.">

  <!-- Hero -->
  <section class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <span class="inline-block bg-emerald-50 text-emerald-700 text-xs font-medium px-3 py-1 rounded-full uppercase tracking-wide mb-4">Parent Portal</span>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight">Welcome back.</h1>
      <p class="text-lg text-slate-600 mt-6 max-w-2xl">Quick links to your ParentSquare account, this month's alerts, and answers to common questions.</p>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Quick Links</h2>
      <p class="text-slate-600 mb-10 max-w-3xl">
        These links open ParentSquare directly. If you're signed in, you'll land on the page. If not, ParentSquare will sign you in first.
      </p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {parentSquareLinks.map(link => (
          <a href={link.url} target="_blank" rel="noopener" class="group bg-white rounded-xl p-6 border border-slate-200 hover:border-emerald-300 hover:shadow-lg transition-all">
            <div class="w-10 h-10 bg-emerald-50 rounded-lg flex items-center justify-center mb-4 group-hover:bg-emerald-600 transition-colors">
              <svg class="w-5 h-5 text-emerald-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[link.icon]}/></svg>
            </div>
            <h3 class="font-semibold text-slate-900 mb-2">{link.label}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{link.description}</p>
            <p class="text-xs text-emerald-700 font-medium mt-4 group-hover:text-emerald-800">Open ParentSquare →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Monthly Alerts -->
  <section class="bg-white border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <div class="flex items-baseline justify-between flex-wrap gap-2 mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900">This Month's Alerts</h2>
        <span class="text-xs uppercase tracking-wider text-slate-500 font-medium">{currentMonth}</span>
      </div>
      {alerts.length === 0 ? (
        <p class="text-slate-500 italic">No alerts this month.</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {alerts.map(a => (
            <div class={`${alertTypeStyles[a.type || 'info']} border rounded-xl p-5`}>
              <p class="text-xs uppercase tracking-wider font-semibold mb-2 opacity-70">{a.date}</p>
              <h3 class="font-semibold mb-2">{a.title}</h3>
              <p class="text-sm leading-relaxed">{a.description}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-slate-50">
    <div class="max-w-4xl mx-auto px-6 py-16">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">Frequently Asked Questions</h2>
      <p class="text-slate-600 mb-10">Click a question to expand.</p>
      <div class="space-y-3">
        {parentFAQ.map(q => (
          <details class="group bg-white rounded-xl border border-slate-200">
            <summary class="cursor-pointer list-none p-5 flex items-center justify-between gap-4">
              <h3 class="font-semibold text-slate-900 text-sm md:text-base">{q.question}</h3>
              <svg class="w-5 h-5 text-slate-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
            </summary>
            <div class="px-5 pb-5 text-slate-700 text-sm leading-relaxed">{q.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Need help -->
  <section class="bg-emerald-600 text-white">
    <div class="max-w-4xl mx-auto px-6 py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Can't find what you need?</h2>
      <p class="text-emerald-50 mb-10 max-w-xl mx-auto">Email or call the front office and we'll help.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`mailto:${email}`} class="inline-block px-6 py-3 bg-white text-emerald-700 rounded-md text-sm font-medium hover:bg-emerald-50">{email}</a>
        <a href={phoneTel} class="inline-block px-6 py-3 border border-white/40 rounded-md text-sm font-medium hover:bg-white/10">Call {phone}</a>
      </div>
    </div>
  </section>

</LayoutC>
