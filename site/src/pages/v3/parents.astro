---
import LayoutC from '../../layouts/LayoutC.astro';
import { parentSquareLinks } from '../../data/parentSquareLinks';
import { parentFAQ } from '../../data/parentFAQ';
import { alerts, currentMonth } from '../../data/monthlyAlerts';
import { phone, phoneTel, email } from '../../data/campusInfo';

const alertTypeStyles: Record<string, string> = {
  closure: 'bg-red-50 border-red-200 text-red-900',
  'half-day': 'bg-amber-50 border-amber-200 text-amber-900',
  event: 'bg-emerald-50 border-emerald-200 text-emerald-900',
  deadline: 'bg-orange-50 border-orange-200 text-orange-900',
  info: 'bg-slate-50 border-slate-200 text-slate-900',
};

