---
import LayoutC from '../../layouts/LayoutC.astro';
import { annualFundTiers } from '../../data/givingTiers';
import { monthlyTiers } from '../../data/monthlyGivingTiers';

const BASE = import.meta.env.BASE_URL;
---

<LayoutC title="Support" description="Give to Pear Tree Community School. Bridge the gap between what families can pay and what it costs to provide a liberatory education.">

  <!-- Hero -->
  <section class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <span class="inline-block bg-emerald-50 text-emerald-700 text-xs font-medium px-3 py-1 rounded-full uppercase tracking-wide mb-4">Support Pear Tree</span>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight max-w-3xl">Invest in education that transforms.</h1>
    </div>
  </section>

  <!-- Metric Bar -->
  <section class="bg-slate-900 text-white">
    <div class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-3 gap-6">
      <div><p class="text-3xl font-bold text-emerald-400">80%</p><p class="text-xs text-slate-400 mt-1 uppercase tracking-wider">Receive aid</p></div>
      <div><p class="text-3xl font-bold text-emerald-400">95%</p><p class="text-xs text-slate-400 mt-1 uppercase tracking-wider">Students of color</p></div>
      <div><p class="text-3xl font-bold text-emerald-400">$0</p><p class="text-xs text-slate-400 mt-1 uppercase tracking-wider">Family ever turned away</p></div>
    </div>
  </section>

  <!-- Tuition Gap -->
  <section class="bg-slate-50">
    <div class="max-w-4xl mx-auto px-6 py-20 md:py-24">
      <div class="bg-white rounded-2xl p-10 md:p-12 border border-slate-200 text-center">
        <p class="text-lg text-slate-700 leading-relaxed mb-6">
          80% of our families receive financial aid. Tuition alone covers only a fraction of what it costs to deliver our Montessori, social justice, and nature-based curriculum. <strong class="text-slate-900">Your gift directly bridges the gap</strong> between what families can pay and what it costs to educate each child.
        </p>
        <p class="text-emerald-700 text-xl md:text-2xl font-semibold italic">
          When you give to Pear Tree, you are making it possible for a child to stay.
        </p>
      </div>
    </div>
  </section>

  <!-- Annual Fund Tiers -->
  <section id="give" class="bg-white scroll-mt-20">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <p class="text-xs uppercase tracking-wider text-emerald-700 font-medium mb-3">Annual Fund</p>
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-12 max-w-3xl">Every gift, at any level, sustains the education our students depend on.</h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {annualFundTiers.map(tier => (
          <div class="bg-slate-50 rounded-xl p-6 border border-slate-200 hover:shadow-lg transition-shadow">
            <h3 class="font-semibold text-slate-900 text-lg">{tier.name}</h3>
            <p class="text-emerald-700 font-semibold text-sm mt-1">{tier.amount}</p>
            <p class="text-sm text-slate-600 mt-3 leading-relaxed">{tier.impact}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Donation Embed -->
  <section id="donate" class="bg-slate-50 scroll-mt-20">
    <div class="max-w-3xl mx-auto px-6 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-3">Make your gift</h2>
      <p class="text-slate-600 mb-12">Choose a one-time or monthly contribution at any amount.</p>
      <div class="bg-white rounded-2xl p-12 border border-slate-200 min-h-[200px] flex items-center justify-center">
        <div class="text-center">
          <p class="text-slate-400 text-sm mb-4">[ Donorbox donation form will be embedded here ]</p>
          <p class="text-slate-500 text-xs">
            To embed: replace this div with<br />
            <code class="bg-slate-100 px-2 py-1 rounded text-xs">&lt;script src="https://donorbox.org/widget.js"&gt;&lt;/script&gt;</code>
          </p>
        </div>
      </div>
      <p class="text-xs text-slate-500 mt-6">Your gift may be tax-deductible. Contact us for details about our fiscal sponsorship arrangement.</p>
    </div>
  </section>

  <!-- Monthly Giving -->
  <section class="bg-white">
    <div class="max-w-5xl mx-auto px-6 py-20 md:py-24">
      <div class="bg-emerald-600 text-white rounded-2xl p-10 md:p-12">
        <p class="text-xs uppercase tracking-wider text-emerald-200 mb-3">The Orchard</p>
        <h2 class="text-2xl md:text-3xl font-bold mb-4">Sustain us, monthly</h2>
        <p class="text-emerald-50 leading-relaxed mb-8 max-w-2xl">
          Monthly donors are the roots that sustain Pear Tree year-round. By joining The Orchard, you provide predictable, sustained support that allows us to plan ahead and serve more families.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-8">
          {monthlyTiers.map(t => (
            <div class="bg-white/10 backdrop-blur-sm rounded-lg p-4 text-center border border-white/20">
              <p class="font-semibold">{t.amount}</p>
              <p class="text-xs text-emerald-100 mt-1">{t.label}</p>
            </div>
          ))}
        </div>
        <a href="#donate" class="inline-block px-6 py-3 bg-white text-emerald-700 rounded-md text-sm font-medium hover:bg-emerald-50">Start Monthly Giving →</a>
      </div>
    </div>
  </section>

  <!-- Other Ways -->
  <section class="bg-slate-50 border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-12">Other ways to support</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <div class="w-10 h-10 bg-emerald-50 rounded-full flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007Z"/></svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Classroom Wishlist</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Purchase specific items our classrooms need — from Montessori materials to art supplies — shipped directly to the school.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <div class="w-10 h-10 bg-emerald-50 rounded-full flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25"/></svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Employer Matching</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Many Bay Area employers — Google, Apple, Meta, Salesforce — match charitable gifts up to $10,000/year. Double your impact.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <div class="w-10 h-10 bg-emerald-50 rounded-full flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.05 4.575a1.575 1.575 0 1 0-3.15 0v3m3.15-3v-1.5a1.575 1.575 0 0 1 3.15 0v1.5m-3.15 0 .075 5.925"/></svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Volunteer</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Join our community as a volunteer. Parents contribute required annual volunteer hours — and we welcome community members too.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Walk-a-Thon -->
  <section class="bg-slate-900 text-white">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="bg-emerald-600 rounded-2xl p-10 md:p-12 text-center">
        <p class="text-xs uppercase tracking-wider text-emerald-100 mb-3">Annual Event</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">5th Annual Walk-a-Thon</h2>
        <p class="text-emerald-50 mb-2">April 26, 2026 · Oakland Tech High School Track &amp; Field</p>
        <p class="text-emerald-100 mb-8">Join families, students, and supporters for our biggest community fundraiser of the year.</p>
        <a href={`${BASE}/v3/contact`} class="inline-block px-6 py-3 bg-white text-emerald-700 rounded-md text-sm font-medium hover:bg-emerald-50">Get Involved</a>
      </div>
    </div>
  </section>

</LayoutC>
