---
import LayoutC from '../../layouts/LayoutC.astro';
---

<LayoutC title="Home" description="Pear Tree Community School — Social justice Montessori education in Oakland, CA. 90% of students exceed literacy benchmarks.">

  <!-- Hero: Clean institutional with image -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 pt-16 pb-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-emerald-50 text-emerald-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
            Now enrolling for 2026-27
          </div>
          <h1 class="text-4xl lg:text-5xl font-bold text-slate-900 leading-tight mb-6">
            Social justice Montessori education in Oakland
          </h1>
          <p class="text-lg text-slate-500 leading-relaxed mb-8">
            Preschool through 5th grade. Where 90% of students exceed literacy benchmarks, 80% of families receive financial aid, and tuition is need-based.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={`${import.meta.env.BASE_URL}/v3/tour`} class="px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-700 transition-colors text-sm">Schedule a Tour</a>
            <a href={`${import.meta.env.BASE_URL}/programs`} class="px-6 py-3 bg-slate-100 text-slate-700 font-semibold rounded-lg hover:bg-slate-200 transition-colors text-sm">View Programs</a>
          </div>
        </div>
        <div class="relative">
          <img loading="lazy" decoding="async" src={`${import.meta.env.BASE_URL}/images/hero-students.jpg`} alt="Students at Pear Tree" class="w-full rounded-2xl shadow-lg" />
          <div class="absolute -bottom-4 -right-4 bg-white rounded-xl shadow-lg p-4 border border-slate-100">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-900">90% literacy rate</p>
                <p class="text-xs text-slate-500">Exceeding national benchmarks</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Metrics bar -->
  <section class="border-y border-slate-200 bg-white">
    <div class="max-w-7xl mx-auto px-6 py-8 grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center">
        <p class="text-3xl font-bold text-emerald-600">90%</p>
        <p class="text-xs text-slate-500 mt-1">Exceed literacy benchmarks</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-bold text-emerald-600">80%</p>
        <p class="text-xs text-slate-500 mt-1">Receive financial aid</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-bold text-emerald-600">95%</p>
        <p class="text-xs text-slate-500 mt-1">Students of color</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-bold text-emerald-600">2012</p>
        <p class="text-xs text-slate-500 mt-1">Founded in Oakland</p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-wider text-emerald-600 mb-3">Our Approach</p>
        <h2 class="text-3xl font-bold text-slate-900 mb-6">Academic excellence through a social justice lens</h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          While only 22% of Black and Latino students nationally reach proficiency in literacy, 90% of Pear Tree students exceed benchmarks. We prove every day that when children see themselves reflected in their education, they thrive.
        </p>
        <p class="text-slate-600 leading-relaxed">
          Our decolonial Montessori curriculum centers BIPOC communities — not as an afterthought, but as the foundation. Students begin with pre-colonial history, study ancient civilizations, then explore postcolonial resistance movements.
        </p>
      </div>
    </div>
  </section>

  <!-- Four Pillars: Clean cards -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <p class="text-xs font-semibold uppercase tracking-wider text-emerald-600 mb-3">Academic Framework</p>
      <h2 class="text-3xl font-bold text-slate-900 mb-3">Four pillars of the Pear Tree model</h2>
      <p class="text-slate-500 mb-12 max-w-2xl">Supporting students as producers of academic and cultural content and critical thinkers of cultural and academic consumption.</p>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200 hover:border-emerald-300 transition-colors">
          <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center mb-4">
            <span class="text-emerald-700 font-bold text-sm">1</span>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Social Justice &amp; Civic Engagement</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Historical curriculum connecting students to ancestral contributions in math, literature, philosophy, and the arts.</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200 hover:border-orange-300 transition-colors">
          <div class="w-8 h-8 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
            <span class="text-orange-700 font-bold text-sm">2</span>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Cultural Art Enrichments</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Expressive arts rooted in student traditions — addressing historical trauma and supporting agency through creation.</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200 hover:border-amber-300 transition-colors">
          <div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center mb-4">
            <span class="text-amber-700 font-bold text-sm">3</span>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Rigorous Academics</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Montessori-aligned content deepening independence, writing ability, mathematical creativity, and scientific wonder.</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 border border-slate-200 hover:border-blue-300 transition-colors">
          <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <span class="text-blue-700 font-bold text-sm">4</span>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Social &amp; Emotional Learning</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Peer community, emotional literacy, and navigating social dynamics with thoughtfulness and intention.</p>
        </div>
      </div>

      <!-- Structural commitments -->
      <div class="mt-8 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        {['Multi-age classrooms', 'Small class sizes', 'Two teachers/class', 'Anti-bias training', 'Meals provided', 'Parent education'].map(item => (
          <div class="bg-emerald-50 rounded-lg px-3 py-2 text-center">
            <p class="text-xs font-medium text-emerald-700">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Programs: Tabular layout -->
  <section class="bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <p class="text-xs font-semibold uppercase tracking-wider text-emerald-600 mb-3">Programs</p>
      <h2 class="text-3xl font-bold text-slate-900 mb-12">From preschool through 5th grade</h2>

      <div class="grid lg:grid-cols-3 gap-6">
        <!-- Preschool -->
        <div class="bg-white rounded-xl overflow-hidden border border-slate-200 hover:shadow-lg transition-shadow">
          <div class="aspect-[16/10] overflow-hidden">
            <img loading="lazy" decoding="async" src={`${import.meta.env.BASE_URL}/images/classroom-photo.jpg`} alt="Preschool classroom" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs font-semibold bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded">Ages 2+</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Preschool</h3>
            <p class="text-sm text-slate-500 mb-3">Dragonfly &amp; Butterfly classrooms. Montessori Practical Life, Sensory, and Cultural Studies.</p>
            <div class="text-xs text-slate-400 space-y-1">
              <p>Mon-Fri, 8:00 AM - 5:00 PM</p>
              <p>8100 Winthrope Street</p>
            </div>
          </div>
        </div>

        <!-- Elementary -->
        <div class="bg-white rounded-xl overflow-hidden border border-slate-200 hover:shadow-lg transition-shadow">
          <div class="aspect-[16/10] overflow-hidden">
            <img loading="lazy" decoding="async" src={`${import.meta.env.BASE_URL}/images/montessori-classroom.jpg`} alt="Elementary classroom" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs font-semibold bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded">TK-5th</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Elementary</h3>
            <p class="text-sm text-slate-500 mb-3">Hummingbird, Falcon &amp; Dolphin classrooms. Project-based learning with social justice lens.</p>
            <div class="text-xs text-slate-400 space-y-1">
              <p>Mon-Fri, 8:30 AM - 3:30 PM</p>
              <p>6925 Chabot Road</p>
            </div>
          </div>
        </div>

        <!-- Summer Camp -->
        <div class="bg-white rounded-xl overflow-hidden border border-slate-200 hover:shadow-lg transition-shadow">
          <div class="aspect-[16/10] overflow-hidden">
            <img loading="lazy" decoding="async" src={`${import.meta.env.BASE_URL}/images/early-days.jpg`} alt="Student on field trip" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs font-semibold bg-amber-100 text-amber-700 px-2 py-0.5 rounded">Ages 5-9</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Summer Camp</h3>
            <p class="text-sm text-slate-500 mb-3">Eight themed weeks with daily math, arts, and outdoor exploration. Aftercare available.</p>
            <div class="text-xs text-slate-400 space-y-1">
              <p>June 15 - August 7, 2026</p>
              <p>$475/week</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Enrichments -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-emerald-600 mb-3">Beyond Academics</p>
          <h2 class="text-3xl font-bold text-slate-900 mb-6">Enrichments &amp; experiential learning</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-slate-900 mb-1">Sound Recording &amp; Video Production</h3>
                <p class="text-sm text-slate-500">Students create documentaries, video journals, and original songs from songwriting through final mix.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-slate-900 mb-1">Cultural Arts &amp; Movement</h3>
                <p class="text-sm text-slate-500">Art, music, dance, Capoeira, and Spanish with The People's Conservatory. Gardening and culinary arts.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-slate-900 mb-1">Educational Journeys</h3>
                <p class="text-sm text-slate-500">Curriculum-aligned trips: Chabot Space Center, Oakland Museum, DeYoung, UC Berkeley Botanical Garden, and multi-day cultural immersions.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <img loading="lazy" decoding="async" src={`${import.meta.env.BASE_URL}/images/enrichment-performance.jpg`} alt="Egyptian museum field trip" class="rounded-xl w-full h-48 object-cover" />
          <img loading="lazy" decoding="async" src={`${import.meta.env.BASE_URL}/images/homepage-1.jpg`} alt="Student artwork" class="rounded-xl w-full h-48 object-cover" />
          <img loading="lazy" decoding="async" src={`${import.meta.env.BASE_URL}/images/early-days.jpg`} alt="Science museum" class="rounded-xl w-full h-48 object-cover" />
          <img loading="lazy" decoding="async" src={`${import.meta.env.BASE_URL}/images/homepage-3.jpg`} alt="Students collaborating" class="rounded-xl w-full h-48 object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="bg-emerald-600">
    <div class="max-w-4xl mx-auto px-6 py-16 text-center">
      <blockquote>
        <p class="text-xl md:text-2xl font-medium text-white leading-relaxed">
          "The thoughtfulness, creativity and love of the teachers — staff really 'see' each child and support healthy peer relationships."
        </p>
        <footer class="mt-6 text-emerald-200 text-sm">&mdash; Pear Tree Parent, via Berkeley Parents Network</footer>
      </blockquote>
    </div>
  </section>

  <!-- Financial Aid -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="bg-slate-50 rounded-2xl p-8 md:p-12 border border-slate-200">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-emerald-600 mb-3">Financial Aid</p>
            <h2 class="text-3xl font-bold text-slate-900 mb-4">Financial aid for every family</h2>
            <p class="text-slate-600 leading-relaxed">
              80% of Pear Tree families receive financial aid. We offer sliding scale tuition because access to excellent education is a right, not a privilege. BASIC Fund scholarships also available.
            </p>
          </div>
          <div class="space-y-3">
            {['80% of families receive need-based aid', 'Sliding scale based on ability to pay', 'Need-based tuition conversations', 'BASIC Fund scholarships (up to $2,750/yr)'].map(item => (
              <div class="flex items-center gap-3 bg-white rounded-lg px-4 py-3 border border-slate-200">
                <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                <span class="text-sm text-slate-700">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-slate-900">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to learn more?</h2>
      <p class="text-slate-400 max-w-xl mx-auto mb-8">
        Schedule a campus tour to see our classrooms, meet our teachers, and find out how Pear Tree can be the right fit for your family.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={`${import.meta.env.BASE_URL}/v3/tour`} class="px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-700 transition-colors text-sm">Schedule a Tour</a>
        <a href={`${import.meta.env.BASE_URL}/support`} class="px-6 py-3 bg-white text-slate-900 font-semibold rounded-lg hover:bg-slate-100 transition-colors text-sm">Make a Gift</a>
        <a href="tel:+15108174690" class="px-6 py-3 border border-slate-600 text-slate-300 font-semibold rounded-lg hover:bg-slate-800 transition-colors text-sm">Call (510) 817-4690</a>
      </div>
    </div>
  </section>

</LayoutC>
