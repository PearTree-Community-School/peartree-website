---
import Layout from '../layouts/Layout.astro';
import StaffRequestForm from '../components/StaffRequestForm.astro';
import { requestCategories } from '../data/staffRequestCategories';
import { phone, phoneTel, email } from '../data/campusInfo';
---

<Layout title="Staff Portal" description="Pear Tree Community School staff portal — submit work requests for facilities, supplies, tech, Montessori materials, and more.">

  <!-- Hero -->
  <section class="bg-forest-900 text-white">
    <div class="section-padding py-16 md:py-20">
      <p class="text-pear-400 font-semibold text-sm uppercase tracking-widest mb-4">Staff Portal</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold leading-tight">Submit a work request.</h1>
      <p class="text-forest-200 text-lg mt-4 max-w-2xl">
        For facilities, supplies, tech, Montessori materials, or anything else you need to do your job well.
      </p>
    </div>
  </section>

  <!-- Auth-coming-soon banner -->
  <section class="bg-pear-100 border-b border-pear-200">
    <div class="section-padding py-4">
      <p class="text-sm text-charcoal max-w-4xl mx-auto">
        <strong>Staff portal — currently open submissions.</strong> Login will be required soon (admin invite by email). Until then, please use thoughtfully; submissions email <a href={`mailto:${email}`} class="underline">{email}</a>.
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="grid md:grid-cols-3 gap-12 max-w-6xl mx-auto">

      <!-- Categories sidebar -->
      <div class="md:col-span-1">
        <h2 class="section-heading mb-6">What can I request?</h2>
        <ul class="space-y-3">
          {requestCategories.map(c => (
            <li class="flex items-start gap-3 text-sm">
              <span class="text-forest-600 mt-1">●</span>
              <div>
                <p class="font-semibold text-charcoal">{c.label}</p>
                <p class="text-earth-600 text-xs">{c.desc}</p>
              </div>
            </li>
          ))}
        </ul>

        <div class="bg-pear-50 border border-pear-200 rounded-2xl p-6 mt-8">
          <h3 class="font-serif font-bold text-base mb-2">Urgent?</h3>
          <p class="text-sm text-earth-700 mb-3">
            If something is dangerous or blocking your class right now, please also call the front office directly.
          </p>
          <a href={phoneTel} class="text-sm text-forest-700 font-semibold underline">{phone}</a>
        </div>
      </div>

      <!-- Form -->
      <div class="md:col-span-2">
        <div class="bg-white rounded-2xl p-8 border border-earth-100">
          <h2 class="font-serif text-2xl font-bold mb-2">New request</h2>
          <p class="text-sm text-earth-500 mb-6">Required fields are marked with *. Photos are great for facilities/maintenance.</p>
          <StaffRequestForm variant="v1" />
        </div>
      </div>
    </div>
  </section>

</Layout>
