---
import LayoutB from '../../layouts/LayoutB.astro';
import { preschool, elementary, phone, phoneTel, email, facebook } from '../../data/campusInfo';
---

<LayoutB title="Contact" description="Contact Pear Tree Community School in Oakland, CA.">

  <!-- Hero -->
  <section class="bg-neutral-900 text-white">
    <div class="max-w-7xl mx-auto px-6 py-24 md:py-32">
      <p class="text-xs uppercase tracking-[0.3em] text-amber-400 mb-6">Contact</p>
      <h1 class="text-5xl md:text-7xl font-bold leading-[1.05] max-w-4xl" style="font-family: 'Playfair Display', serif;">We'd love to hear from you.</h1>
    </div>
  </section>

  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-24 grid md:grid-cols-2 gap-16">

      <!-- Contact Info -->
      <div>
        <h2 class="text-3xl md:text-4xl font-bold mb-12" style="font-family: 'Playfair Display', serif;">Get in touch.</h2>

        <div class="space-y-8 mb-12">
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-amber-600 mb-2">Phone</p>
            <a href={phoneTel} class="text-2xl font-bold hover:text-amber-600 transition-colors" style="font-family: 'Playfair Display', serif;">{phone}</a>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-amber-600 mb-2">Email</p>
            <a href={`mailto:${email}`} class="text-2xl font-bold hover:text-amber-600 transition-colors" style="font-family: 'Playfair Display', serif;">{email}</a>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.3em] text-amber-600 mb-2">Facebook</p>
            <a href={facebook} target="_blank" rel="noopener" class="text-lg hover:text-amber-600 transition-colors">facebook.com/peartreecs</a>
          </div>
        </div>

        <hr class="border-neutral-200 my-12" />

        <div class="space-y-10">
          <div>
            <h3 class="text-2xl font-bold mb-3" style="font-family: 'Playfair Display', serif;">Preschool Campus</h3>
            <address class="not-italic text-neutral-600 leading-relaxed">
              {preschool.address}<br />
              {preschool.city}
            </address>
            <p class="text-sm text-neutral-500 mt-1">{preschool.days}, {preschool.hours}</p>
            <a href={preschool.mapsUrl} target="_blank" rel="noopener" class="text-sm text-amber-600 hover:text-amber-700 inline-block mt-2">View on Google Maps →</a>
          </div>
          <div>
            <h3 class="text-2xl font-bold mb-3" style="font-family: 'Playfair Display', serif;">Elementary Campus</h3>
            <address class="not-italic text-neutral-600 leading-relaxed">
              {elementary.address}<br />
              {elementary.city} {elementary.zip}
            </address>
            <p class="text-sm text-neutral-500 mt-1">{elementary.days}, {elementary.hours}</p>
            <a href={elementary.mapsUrl} target="_blank" rel="noopener" class="text-sm text-amber-600 hover:text-amber-700 inline-block mt-2">View on Google Maps →</a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-neutral-100 rounded-2xl p-10 md:p-12 self-start">
        <h2 class="text-3xl font-bold mb-3" style="font-family: 'Playfair Display', serif;">Send us a message</h2>
        <p class="text-neutral-600 text-sm mb-8">Interested in a tour, enrollment, or volunteering? Let us know.</p>
        <form name="contact" method="POST" data-netlify="true" class="space-y-5">
          <input type="hidden" name="form-name" value="contact" />
          <div>
            <label for="name" class="block text-xs uppercase tracking-wider text-neutral-700 mb-2">Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-neutral-300 rounded-lg text-sm bg-white focus:outline-none focus:border-amber-500" />
          </div>
          <div>
            <label for="email" class="block text-xs uppercase tracking-wider text-neutral-700 mb-2">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-neutral-300 rounded-lg text-sm bg-white focus:outline-none focus:border-amber-500" />
          </div>
          <div>
            <label for="phone" class="block text-xs uppercase tracking-wider text-neutral-700 mb-2">Phone <span class="text-neutral-400 normal-case">(optional)</span></label>
            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 border border-neutral-300 rounded-lg text-sm bg-white focus:outline-none focus:border-amber-500" />
          </div>
          <div>
            <label for="interest" class="block text-xs uppercase tracking-wider text-neutral-700 mb-2">I'm interested in</label>
            <select id="interest" name="interest" class="w-full px-4 py-3 border border-neutral-300 rounded-lg text-sm bg-white focus:outline-none focus:border-amber-500">
              <option value="">Select one...</option>
              <option value="tour">Scheduling a tour</option>
              <option value="preschool">Preschool enrollment</option>
              <option value="elementary">Elementary enrollment</option>
              <option value="summer-camp">Summer camp</option>
              <option value="volunteer">Volunteering</option>
              <option value="donate">Making a donation</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-xs uppercase tracking-wider text-neutral-700 mb-2">Message</label>
            <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 border border-neutral-300 rounded-lg text-sm bg-white focus:outline-none focus:border-amber-500 resize-y"></textarea>
          </div>
          <button type="submit" class="w-full px-8 py-4 bg-neutral-900 text-white rounded-full text-sm font-medium hover:bg-amber-500 hover:text-neutral-900 transition-colors">Send Message</button>
        </form>
      </div>
    </div>
  </section>

</LayoutB>
