};

const alertTypeStyles: Record<string, string> = {
  closure: 'border-l-4 border-red-500 bg-red-50',
  'half-day': 'border-l-4 border-amber-500 bg-amber-50',
  event: 'border-l-4 border-forest-500 bg-forest-50',
  deadline: 'border-l-4 border-pear-500 bg-pear-50',
  info: 'border-l-4 border-earth-400 bg-earth-50',
};
---

<Layout title="Parent Portal" description="Pear Tree Community School parent portal — calendar, messages, photos, FAQ, and quick links to ParentSquare.">

  <!-- Hero -->
  <section class="bg-forest-900 text-white">
    <div class="section-padding py-16 md:py-20">
      <p class="text-pear-400 font-semibold text-sm uppercase tracking-widest mb-4">Parent Portal</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold leading-tight">Welcome back.</h1>
      <p class="text-forest-200 text-lg mt-4 max-w-2xl">
        Quick links to your ParentSquare account, this month's alerts, and answers to common questions.
      </p>
    </div>
  </section>

  <!-- Quick Links to ParentSquare -->
  <section class="section-padding">
    <h2 class="section-heading mb-6">Quick Links</h2>
    <p class="text-earth-600 mb-8 max-w-3xl">
      The links below take you into our ParentSquare account. If you're already signed in, they'll open the right page directly. If not, ParentSquare will ask you to log in first, then send you where you wanted to go.
    </p>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-6xl mx-auto">
      {parentSquareLinks.map(link => (
        <a href={link.url} target="_blank" rel="noopener" class="group bg-white border border-earth-100 rounded-2xl p-6 hover:border-forest-400 hover:shadow-lg transition-all">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-forest-100 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-forest-600 transition-colors">
              <svg class="w-5 h-5 text-forest-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[link.icon]}/></svg>
            </div>
            <div class="flex-1">
              <h3 class="font-serif font-bold text-base mb-1 group-hover:text-forest-700 transition-colors">{link.label}</h3>
              <p class="text-sm text-earth-600 leading-snug">{link.description}</p>
            </div>
            <svg class="w-4 h-4 text-earth-400 group-hover:text-forest-600 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M13.5 6L19.5 12L13.5 18M19.5 12H4.5"/></svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Monthly Alerts -->
  <section class="bg-pear-50 border-y border-pear-100">
    <div class="section-padding">
      <div class="flex items-baseline justify-between flex-wrap gap-2 mb-8">
        <h2 class="section-heading">This Month's Alerts</h2>
        <p class="text-earth-600 text-sm">{currentMonth}</p>
      </div>
      {alerts.length === 0 ? (
        <p class="text-earth-500 italic">No alerts this month. Enjoy a quiet calendar.</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-6xl mx-auto">
          {alerts.map(a => (
            <div class={`${alertTypeStyles[a.type || 'info']} rounded-r-xl p-5`}>
              <p class="text-xs uppercase tracking-wider text-earth-500 font-semibold mb-2">{a.date}</p>
              <h3 class="font-serif font-bold mb-2">{a.title}</h3>
              <p class="text-sm text-earth-700 leading-relaxed">{a.description}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-padding">
    <h2 class="section-heading text-center mb-12">Frequently Asked Questions</h2>
    <div class="max-w-3xl mx-auto space-y-3">
      {parentFAQ.map(q => (
        <details class="group bg-white border border-earth-100 rounded-xl">
          <summary class="cursor-pointer list-none p-5 flex items-center justify-between gap-4">
            <h3 class="font-serif font-bold text-base">{q.question}</h3>
            <svg class="w-5 h-5 text-earth-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <div class="px-5 pb-5 text-earth-700 text-sm leading-relaxed">{q.answer}</div>
        </details>
      ))}
    </div>
  </section>

  <!-- Need help -->
  <section class="bg-forest-700 text-white">
    <div class="section-padding text-center">
      <h2 class="font-serif text-3xl font-bold mb-4">Can't find what you need?</h2>
      <p class="text-forest-200 max-w-xl mx-auto mb-8">Email or call the front office and we'll help. The admin team is the best first stop for anything not covered above.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`mailto:${email}`} class="btn-primary bg-pear-500 hover:bg-pear-600 text-charcoal font-bold">{email}</a>
        <a href={phoneTel} class="btn-secondary border-white/30 text-white hover:bg-white/10">Call {phone}</a>
      </div>
    </div>
  </section>

</Layout>
