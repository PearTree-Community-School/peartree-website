---
import { requestCategories, priorityLevels, locations } from '../data/staffRequestCategories';

interface Props {
  variant: 'v1' | 'v2' | 'v3';
}
const { variant } = Astro.props;

const themes = {
  v1: {
    label: 'block text-sm font-medium text-charcoal mb-1',
    input: 'w-full px-4 py-3 border border-earth-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent bg-cream',
    section: 'font-serif text-lg font-bold text-charcoal mb-4 mt-6',
    button: 'btn-primary w-full text-center',
    optional: 'text-earth-400',
    radioWrap: 'flex flex-wrap gap-3',
    radio: 'inline-flex items-center gap-2 px-4 py-2 border border-earth-200 rounded-lg cursor-pointer hover:bg-pear-50 has-[:checked]:bg-forest-700 has-[:checked]:text-white has-[:checked]:border-forest-700',
  },
  v2: {
    label: 'block text-xs uppercase tracking-wider text-neutral-700 mb-2',
    input: 'w-full px-4 py-3 border border-neutral-300 rounded-lg text-sm bg-white focus:outline-none focus:border-amber-500',
    section: 'text-2xl font-bold text-neutral-900 mb-4 mt-8',
    button: 'w-full px-8 py-4 bg-neutral-900 text-white rounded-full text-sm font-medium hover:bg-amber-500 hover:text-neutral-900 transition-colors',
    optional: 'text-neutral-400 normal-case',
    radioWrap: 'flex flex-wrap gap-2',
    radio: 'inline-flex items-center gap-2 px-4 py-2 border border-neutral-300 rounded-full text-sm cursor-pointer hover:bg-neutral-50 has-[:checked]:bg-neutral-900 has-[:checked]:text-white has-[:checked]:border-neutral-900',
  },
  v3: {
    label: 'block text-xs font-medium text-slate-700 mb-1.5',
    input: 'w-full px-3 py-2.5 border border-slate-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500/30 focus:border-emerald-500 bg-white',
    section: 'text-base font-semibold text-slate-900 mb-4 mt-6',
    button: 'w-full px-6 py-3 bg-emerald-600 text-white rounded-md text-sm font-medium hover:bg-emerald-700',
    optional: 'text-slate-400',
    radioWrap: 'flex flex-wrap gap-2',
    radio: 'inline-flex items-center gap-2 px-3 py-1.5 border border-slate-300 rounded-md text-sm cursor-pointer hover:bg-slate-50 has-[:checked]:bg-emerald-600 has-[:checked]:text-white has-[:checked]:border-emerald-600',
  },
};
const t = themes[variant];
const sectionHeadingStyle = variant === 'v2' ? "font-family: 'Playfair Display', serif;" : '';
---

<form name="staff-request" method="POST" data-netlify="true" netlify-honeypot="bot-field" enctype="multipart/form-data" class="space-y-4">
  <input type="hidden" name="form-name" value="staff-request" />
  <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

  <p class={t.section} style={sectionHeadingStyle}>Your info</p>
  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <label for="staff-name" class={t.label}>Your name *</label>
      <input id="staff-name" name="name" type="text" required class={t.input} />
    </div>
    <div>
      <label for="staff-email" class={t.label}>Email *</label>
      <input id="staff-email" name="email" type="email" required class={t.input} />
    </div>
  </div>

  <p class={t.section} style={sectionHeadingStyle}>Request</p>
  <div>
    <label for="staff-category" class={t.label}>Category *</label>
    <select id="staff-category" name="category" required class={t.input}>
      <option value="">Select a category...</option>
      {requestCategories.map(c => <option value={c.label}>{c.label} — {c.desc}</option>)}
    </select>
  </div>
  <div>
    <label for="staff-location" class={t.label}>Location *</label>
    <select id="staff-location" name="location" required class={t.input}>
      <option value="">Select a location...</option>
      {locations.map(l => <option value={l}>{l}</option>)}
    </select>
  </div>

  <div>
    <label class={t.label}>Priority *</label>
    <div class={t.radioWrap}>
      {priorityLevels.map((p, i) => (
        <label class={t.radio}>
          <input type="radio" name="priority" value={p} required={i === 0} class="sr-only" />
          <span>{p}</span>
        </label>
      ))}
    </div>
  </div>

  <div>
    <label for="staff-description" class={t.label}>Description *</label>
    <textarea id="staff-description" name="description" rows="5" required class={t.input + ' resize-y'} placeholder="What's needed? Be as specific as you can — room, item, when it happens, etc."></textarea>
  </div>

  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <label for="staff-needed-by" class={t.label}>Needed by <span class={t.optional}>(optional)</span></label>
      <input id="staff-needed-by" name="needed_by" type="date" class={t.input} />
    </div>
    <div>
      <label for="staff-photo" class={t.label}>Photo <span class={t.optional}>(optional)</span></label>
      <input id="staff-photo" name="photo" type="file" accept="image/*" class={t.input + ' file:mr-3 file:px-3 file:py-1 file:rounded file:border-0 file:bg-gray-200 file:text-sm'} />
    </div>
  </div>

  <button type="submit" class={`${t.button} mt-6`}>Submit Request</button>
</form>
