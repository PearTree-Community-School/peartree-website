---
const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/programs', label: 'Programs' },
  { href: '/admissions', label: 'Admissions' },
  { href: '/support', label: 'Support' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
const BASE = import.meta.env.BASE_URL;
---

<header class="bg-white/95 backdrop-blur-sm border-b border-earth-100 sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo / School Name -->
    <a href={`${import.meta.env.BASE_URL}/`} class="flex items-center gap-3 group">
      <img src={`${import.meta.env.BASE_URL}/images/logo.jpg`} alt="Pear Tree" class="h-10 w-auto" />
      <div>
        <span class="font-serif font-bold text-lg text-charcoal leading-tight block">Pear Tree</span>
        <span class="text-xs text-earth-500 leading-tight block">Community School</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={`${BASE}${link.href}`}
          class:list={[
            'text-sm font-medium transition-colors duration-200',
            currentPath.startsWith(`${BASE}${link.href}`)
              ? 'text-forest-700'
              : 'text-earth-600 hover:text-forest-700'
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href={`${import.meta.env.BASE_URL}/support#give`} class="btn-give text-sm">Give</a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-earth-600 hover:text-charcoal"
      aria-label="Open menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-earth-100 bg-white">
    <div class="px-6 py-4 space-y-3">
      {navLinks.map(link => (
        <a
          href={`${BASE}${link.href}`}
          class:list={[
            'block text-sm font-medium py-2',
            currentPath.startsWith(`${BASE}${link.href}`)
              ? 'text-forest-700'
              : 'text-earth-600'
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href={`${import.meta.env.BASE_URL}/support#give`} class="btn-give text-sm block text-center mt-4">Give</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
